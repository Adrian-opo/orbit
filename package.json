{
  "name": "orbit",
  "version": "0.1.0",
  "description": "Orbit — multi-session Claude Code agent dashboard",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:mock": "vite dev --mode mock",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cd front && cargo test",
    "lint": "npm run lint:front && npm run lint:api",
    "lint:front": "cargo clippy --manifest-path front/Cargo.toml -- -D warnings",
    "lint:api": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri -c front/tauri.conf.json",
    "tauri:dev": "tauri dev -c front/tauri.conf.json",
    "tauri:build": "tauri build -c front/tauri.conf.json",
    "tauri:icon": "tauri icon -c front/tauri.conf.json"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
