{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:allow-open",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "orbit-mcp", "sidecar": true }]
    }
  ]
}
